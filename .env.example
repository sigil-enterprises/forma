# forma — environment variables
# Copy to .env and fill in your values. Never commit .env to version control.

# ── Claude Composer ────────────────────────────────────────────────────────
# Required for: forma compose fill / forma compose enrich
ANTHROPIC_API_KEY=sk-ant-...

# ── Google Drive publishing ────────────────────────────────────────────────
# Required for: forma publish
# Value: base64-encoded service account JSON
#   openssl base64 -in service-account.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Skills: Google Docs ────────────────────────────────────────────────────
# Required for: forma compose enrich --skills google_docs
GOOGLE_DOCS_ID=

# ── Skills: Google Sheets ─────────────────────────────────────────────────
# Required for: forma compose enrich --skills google_sheets
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_RANGE=Sheet1!A1:Z

# ── Skills: ClickUp ───────────────────────────────────────────────────────
# Required for: forma compose enrich --skills clickup
CLICKUP_API_TOKEN=
CLICKUP_LIST_ID=

# ── Skills: Meeting notes ──────────────────────────────────────────────────
# Required for: forma compose enrich --skills meeting_notes
# (can also be passed as --notes flag)
MEETING_NOTES_PATH=

# ── CI / devcontainer ─────────────────────────────────────────────────────
# GitHub personal access token (repo read scope) — used by CI and devcontainer
GITHUB_TOKEN=ghp_...

# Organisation name — used by setup-host to configure git URL rewrites
ORGANIZATION=slivern-corporate-services
