# Rust build artifacts
/target/
**/*.rs.bk
*.pdb

# Environments / secrets
.env
.envrc
.local

# Logs
logs
*.log
nohup.out

# OS noise
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# Build outputs
site/

# Note: .toolchain/ is NOT excluded here. The directory itself is tracked
# (so its inner .gitignore is committed), and that inner .gitignore excludes
# every chain-storage snapshot. Same pattern: .toolkit/ is fully tracked.
