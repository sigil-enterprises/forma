<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=1280">
<title>(( document.slides.0.title | default('Presentation') ))</title>
<style>
/* ── Fonts ─────────────────────────────────────────────────────────────── */
@font-face {
  font-family: 'Rubik';
  src: url('../../fonts/rubik/Rubik-VariableFont.ttf') format('truetype');
  font-weight: 100 900;
  font-style: normal;
}
@font-face {
  font-family: 'Rubik';
  src: url('../../fonts/rubik/Rubik-VariableFont-Italic.ttf') format('truetype');
  font-weight: 100 900;
  font-style: italic;
}

/* ── CSS custom properties from style.yaml ─────────────────────────────── */
:root {
  --primary:      (( style.colors.primary_dark   | default('#061E30') ));
  --gold:         (( style.colors.primary_accent | default('#FDB62B') ));
  --amber:        (( style.colors.accent_amber   | default('#F8942B') ));
  --orange:       (( style.colors.accent_orange  | default('#F06134') ));
  --text-main:    (( style.colors.text_primary   | default('#061E30') ));
  --text-sub:     (( style.colors.text_secondary | default('#4B5563') ));
  --gray-light:   (( style.colors.gray_light     | default('#F7F8FA') ));
  --gray-medium:  (( style.colors.gray_medium    | default('#E4E7EC') ));
  --white:        #ffffff;

  --slide-w: 1280px;
  --slide-h: 720px;
}

/* ── Reset ─────────────────────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Rubik', 'Helvetica Neue', sans-serif;
  font-size: 16px;
  background: #888;
}

/* ── Slide canvas ──────────────────────────────────────────────────────── */
.slide {
  width: var(--slide-w);
  height: var(--slide-h);
  background: var(--white);
  color: var(--text-main);
  overflow: hidden;
  position: relative;
  display: flex;
  flex-direction: column;
}

/* ── Print ─────────────────────────────────────────────────────────────── */
@page {
  size: 1280px 720px;
  margin: 0;
}
@media print {
  body { background: none; }
  .slide {
    break-after: page;
    page-break-after: always;
  }
  .slide:last-child {
    break-after: avoid;
    page-break-after: avoid;
  }
}

/* ── Header bar (all content slides) ──────────────────────────────────── */
.slide-header {
  background: var(--primary);
  padding: 10px 28px 8px;
  display: flex;
  align-items: center;
  flex-shrink: 0;
}
.slide-header h1 {
  color: var(--white);
  font-size: 17px;
  font-weight: 700;
  letter-spacing: 0.01em;
}
.header-accent {
  height: 5px;
  background: linear-gradient(
    to right,
    var(--gold) 0%,
    var(--gold) 60%,
    var(--amber) 60%,
    var(--amber) 80%,
    var(--orange) 80%,
    var(--orange) 100%
  );
  flex-shrink: 0;
}

/* ── Footer ────────────────────────────────────────────────────────────── */
.slide-footer {
  background: var(--gray-light);
  border-top: 1px solid var(--gray-medium);
  padding: 0 28px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
  margin-top: auto;
}
.slide-footer .footer-left {
  font-size: 9px;
  font-weight: 600;
  color: var(--text-sub);
  letter-spacing: 0.02em;
}
.slide-footer .footer-right {
  font-size: 9px;
  color: var(--text-sub);
}
.footer-sep { color: var(--gray-medium); margin: 0 6px; }

/* ── Content area ──────────────────────────────────────────────────────── */
.slide-body {
  flex: 1;
  padding: 20px 28px 16px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* ── Cover slide ───────────────────────────────────────────────────────── */
.slide.cover {
  background: var(--primary);
  flex-direction: column;
  justify-content: flex-end;
}
.cover-stripe {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 10px;
  background: linear-gradient(
    to right,
    var(--gold) 0%,
    var(--gold) 60%,
    var(--amber) 60%,
    var(--amber) 80%,
    var(--orange) 80%,
    var(--orange) 100%
  );
}
.cover-body {
  padding: 64px 72px 52px;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}
.cover-kicker {
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 20px;
}
.cover-title {
  font-size: 36px;
  font-weight: 700;
  color: var(--white);
  line-height: 1.2;
  max-width: 820px;
  margin-bottom: 16px;
}
.cover-subtitle {
  font-size: 16px;
  font-weight: 400;
  color: rgba(255,255,255,0.7);
  margin-bottom: 36px;
}
.cover-meta {
  display: flex;
  align-items: center;
  gap: 24px;
}
.cover-logo {
  height: 36px;
  opacity: 0.9;
}
.cover-ref {
  font-size: 10px;
  color: rgba(255,255,255,0.45);
  letter-spacing: 0.06em;
}

/* ── Section divider ───────────────────────────────────────────────────── */
.slide.section-divider {
  background: var(--primary);
}
.divider-body {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}
.divider-rule-wrap {
  display: flex;
  align-items: center;
  gap: 20px;
}
.divider-rule {
  width: 48px;
  height: 2px;
  background: var(--gold);
}
.divider-label {
  font-size: 28px;
  font-weight: 700;
  color: var(--white);
  letter-spacing: 0.01em;
}
.section-divider .slide-footer {
  background: transparent;
  border-top: none;
  position: absolute;
  bottom: 0; left: 0; right: 0;
}
.section-divider .footer-left,
.section-divider .footer-right { color: rgba(255,255,255,0.4); }
.section-divider .footer-sep { color: rgba(255,255,255,0.2); }
.divider-stripe {
  position: absolute;
  bottom: 32px; left: 0; right: 0;
  height: 8px;
  background: linear-gradient(
    to right,
    var(--gold) 0%,
    var(--gold) 60%,
    var(--amber) 60%,
    var(--amber) 80%,
    var(--orange) 80%,
    var(--orange) 100%
  );
}

/* ── Exec summary ──────────────────────────────────────────────────────── */
.exec-headline {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 14px;
  line-height: 1.35;
  border-left: 3px solid var(--gold);
  padding-left: 12px;
}
.exec-points {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 9px;
}
.exec-points li {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 13px;
  color: var(--text-sub);
  line-height: 1.4;
}
.exec-points li::before {
  content: '';
  display: block;
  width: 7px;
  height: 7px;
  background: var(--gold);
  border-radius: 1px;
  flex-shrink: 0;
  margin-top: 4px;
}

/* ── Pain-point cards ──────────────────────────────────────────────────── */
.pain-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
  flex: 1;
}
.pain-card {
  background: var(--gray-light);
  border-radius: 4px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}
.pain-card-header {
  background: var(--primary);
  padding: 8px 14px;
}
.pain-card-header h3 {
  font-size: 11px;
  font-weight: 700;
  color: var(--white);
}
.pain-card-body {
  padding: 10px 14px;
  flex: 1;
}
.pain-card-body p {
  font-size: 11px;
  color: var(--text-sub);
  line-height: 1.45;
}

/* ── Metrics slide ─────────────────────────────────────────────────────── */
.metrics-desc {
  font-size: 12px;
  color: var(--text-sub);
  margin-bottom: 20px;
}
.metrics-row {
  display: flex;
  gap: 16px;
  flex: 1;
  align-items: stretch;
}
.metric-card {
  flex: 1;
  background: var(--primary);
  border-radius: 4px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20px 16px;
  text-align: center;
}
.metric-value {
  font-size: 34px;
  font-weight: 700;
  color: var(--gold);
  line-height: 1.1;
  margin-bottom: 10px;
}
.metric-label {
  font-size: 10px;
  font-weight: 500;
  color: rgba(255,255,255,0.75);
  line-height: 1.35;
  text-align: center;
}

/* ── Solution pillars ──────────────────────────────────────────────────── */
.pillars-overview {
  font-size: 12px;
  color: var(--text-sub);
  margin-bottom: 16px;
  line-height: 1.45;
}
.pillars-row {
  display: flex;
  gap: 14px;
  flex: 1;
  align-items: stretch;
}
.pillar {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.pillar-header {
  background: var(--primary);
  padding: 9px 14px;
  border-radius: 4px 4px 0 0;
}
.pillar-header h3 {
  font-size: 11px;
  font-weight: 700;
  color: var(--white);
  line-height: 1.3;
}
.pillar-body {
  background: var(--gray-light);
  padding: 10px 14px;
  flex: 1;
  border-radius: 0 0 4px 4px;
}
.pillar-body p {
  font-size: 11px;
  color: var(--text-sub);
  line-height: 1.45;
}

/* ── Differentiators ───────────────────────────────────────────────────── */
.diff-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 14px;
  flex: 1;
}
.diff-item {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding: 14px 18px;
  background: var(--gray-light);
  border-radius: 4px;
  border-left: 3px solid var(--gold);
}
.diff-item-content h3 {
  font-size: 13px;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 4px;
}
.diff-item-content p {
  font-size: 11.5px;
  color: var(--text-sub);
  line-height: 1.4;
}

/* ── Timeline ──────────────────────────────────────────────────────────── */
.timeline-phases {
  display: flex;
  gap: 0;
  flex: 1;
  align-items: stretch;
}
.phase {
  flex: 1;
  display: flex;
  flex-direction: column;
  position: relative;
}
.phase + .phase::before {
  content: '';
  position: absolute;
  top: 0; left: 0; bottom: 0;
  width: 1px;
  background: var(--gray-medium);
}
.phase-header {
  background: var(--primary);
  padding: 8px 12px;
  margin-right: 1px;
}
.phase-header:last-child { margin-right: 0; }
.phase-label {
  font-size: 10px;
  font-weight: 700;
  color: var(--white);
  margin-bottom: 2px;
}
.phase-duration {
  font-size: 9px;
  color: var(--gold);
  font-weight: 500;
}
.phase-body {
  padding: 10px 12px;
  flex: 1;
  background: var(--gray-light);
  margin-right: 1px;
}
.phase-section-label {
  font-size: 8px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-sub);
  margin-bottom: 5px;
  margin-top: 8px;
}
.phase-section-label:first-child { margin-top: 0; }
.phase-items {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 3px;
}
.phase-items li {
  font-size: 9.5px;
  color: var(--text-main);
  line-height: 1.35;
  padding-left: 9px;
  position: relative;
}
.phase-items li::before {
  content: '–';
  position: absolute;
  left: 0;
  color: var(--gold);
}

/* ── Investment table ──────────────────────────────────────────────────── */
.inv-table-wrap {
  flex: 1;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.inv-phase-block {
  flex: 1;
}
.inv-phase-name {
  font-size: 10px;
  font-weight: 700;
  color: var(--white);
  background: var(--primary);
  padding: 5px 10px;
  border-radius: 3px 3px 0 0;
}
.inv-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 10.5px;
}
.inv-table th {
  background: var(--gray-light);
  color: var(--text-sub);
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 5px 8px;
  text-align: left;
  border-bottom: 1px solid var(--gray-medium);
}
.inv-table th.right { text-align: right; }
.inv-table td {
  padding: 5px 8px;
  color: var(--text-main);
  border-bottom: 1px solid var(--gray-medium);
}
.inv-table td.right { text-align: right; }
.inv-table tr:last-child td { border-bottom: none; }
.inv-total-row td {
  font-weight: 700;
  background: var(--gray-light);
  color: var(--primary);
}
.inv-grand-total {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 16px;
  padding: 10px 0 4px;
}
.inv-grand-label {
  font-size: 11px;
  font-weight: 700;
  color: var(--text-sub);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.inv-grand-value {
  font-size: 22px;
  font-weight: 700;
  color: var(--primary);
}
.inv-notes {
  margin-top: 8px;
  display: flex;
  flex-direction: column;
  gap: 3px;
}
.inv-notes li {
  font-size: 9px;
  color: var(--text-sub);
  list-style: none;
  padding-left: 10px;
  position: relative;
}
.inv-notes li::before {
  content: '*';
  position: absolute;
  left: 0;
  color: var(--gold);
}

/* ── Team grid ─────────────────────────────────────────────────────────── */
.team-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 12px;
  flex: 1;
  align-content: start;
}
.team-card {
  background: var(--gray-light);
  border-radius: 4px;
  overflow: hidden;
}
.team-card-header {
  background: var(--primary);
  padding: 10px 14px;
}
.team-name {
  font-size: 12px;
  font-weight: 700;
  color: var(--white);
  line-height: 1.25;
}
.team-role {
  font-size: 10px;
  color: var(--gold);
  font-weight: 500;
  margin-top: 2px;
}
.team-card-body {
  padding: 10px 14px;
}
.team-expertise {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 3px;
}
.team-expertise li {
  font-size: 10px;
  color: var(--text-sub);
  padding-left: 10px;
  position: relative;
  line-height: 1.35;
}
.team-expertise li::before {
  content: '·';
  position: absolute;
  left: 2px;
  color: var(--gold);
  font-weight: 700;
}

/* ── Next steps ────────────────────────────────────────────────────────── */
.next-intro {
  font-size: 12px;
  color: var(--text-sub);
  margin-bottom: 18px;
}
.steps-row {
  display: flex;
  gap: 16px;
  flex: 1;
}
.step-card {
  flex: 1;
  background: var(--gray-light);
  border-radius: 4px;
  border-top: 3px solid var(--gold);
  padding: 16px 18px;
  display: flex;
  flex-direction: column;
}
.step-num {
  width: 28px;
  height: 28px;
  background: var(--primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 700;
  color: var(--gold);
  margin-bottom: 10px;
  flex-shrink: 0;
}
.step-title {
  font-size: 13px;
  font-weight: 700;
  color: var(--primary);
  margin-bottom: 6px;
}
.step-desc {
  font-size: 11px;
  color: var(--text-sub);
  line-height: 1.45;
}

/* ── Closing slide ─────────────────────────────────────────────────────── */
.slide.closing {
  background: var(--primary);
}
.closing-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24px;
  padding: 40px 72px;
  position: relative;
  z-index: 1;
}
.closing-logo {
  height: 44px;
  opacity: 0.92;
}
.closing-tagline {
  font-size: 26px;
  font-weight: 700;
  color: var(--white);
  text-align: center;
}
.closing-contact {
  display: flex;
  gap: 32px;
  font-size: 12px;
  color: rgba(255,255,255,0.6);
}
.closing-contact a {
  color: var(--gold);
  text-decoration: none;
}
.closing-stripe {
  position: absolute;
  bottom: 32px; left: 0; right: 0;
  height: 8px;
  background: linear-gradient(
    to right,
    var(--gold) 0%,
    var(--gold) 60%,
    var(--amber) 60%,
    var(--amber) 80%,
    var(--orange) 80%,
    var(--orange) 100%
  );
}
.closing .slide-footer {
  background: transparent;
  border-top: none;
  position: absolute;
  bottom: 0; left: 0; right: 0;
}
.closing .footer-left,
.closing .footer-right { color: rgba(255,255,255,0.35); }
.closing .footer-sep { color: rgba(255,255,255,0.15); }

</style>
</head>
<body>

(% set ns = namespace(idx=0) %)
(% for slide in document.slides %)
  (% set ns.idx = ns.idx + 1 %)
  (% if slide.type == 'cover' %)
    (% include 'cover.html.j2' %)
  (% elif slide.type == 'exec_summary' %)
    (% include 'exec_summary.html.j2' %)
  (% elif slide.type == 'section_divider' %)
    (% include 'section_divider.html.j2' %)
  (% elif slide.type == 'pain_points' %)
    (% include 'pain_points.html.j2' %)
  (% elif slide.type == 'metrics' %)
    (% include 'metrics.html.j2' %)
  (% elif slide.type == 'solution_pillars' %)
    (% include 'solution_pillars.html.j2' %)
  (% elif slide.type == 'differentiators' %)
    (% include 'differentiators.html.j2' %)
  (% elif slide.type == 'timeline' %)
    (% include 'timeline.html.j2' %)
  (% elif slide.type == 'investment_table' %)
    (% include 'investment_table.html.j2' %)
  (% elif slide.type == 'team_grid' %)
    (% include 'team_grid.html.j2' %)
  (% elif slide.type == 'next_steps' %)
    (% include 'next_steps.html.j2' %)
  (% elif slide.type == 'closing' %)
    (% include 'closing.html.j2' %)
  (% endif %)
(% endfor %)

</body>
</html>
