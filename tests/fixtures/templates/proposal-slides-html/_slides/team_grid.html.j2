(% set client_name = document.slides | selectattr('type','eq','cover') | map(attribute='client') | first | default('') %)
(% set eng_title = document.slides | selectattr('type','eq','cover') | map(attribute='title') | first | default('') %)
<div class="slide">
  <div class="slide-header"><h1>(( slide.title | default('Our Team') | e ))</h1></div>
  <div class="header-accent"></div>
  <div class="slide-body">
    <div class="team-grid">
      (% for member in slide.consultants %)
      <div class="team-card">
        <div class="team-card-header">
          <div class="team-name">(( member.name | e ))</div>
          <div class="team-role">(( member.role | e ))</div>
        </div>
        <div class="team-card-body">
          (% if member.get('expertise') %)
          <ul class="team-expertise">
            (% for skill in member.get('expertise') %)
            <li>(( skill | e ))</li>
            (% endfor %)
          </ul>
          (% endif %)
        </div>
      </div>
      (% endfor %)
    </div>
  </div>
  <div class="slide-footer">
    <span class="footer-left">(( client_name | e ))(% if client_name and eng_title %)<span class="footer-sep">|</span>(% endif %)(( eng_title | e ))</span>
    <span class="footer-right">(( ns.idx )) / ??</span>
  </div>
</div>
