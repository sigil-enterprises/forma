(% set client_name = document.slides | selectattr('type','eq','cover') | map(attribute='client') | first | default('') %)
(% set eng_title = document.slides | selectattr('type','eq','cover') | map(attribute='title') | first | default('') %)
(% set currency = slide.currency | default('USD') %)
<div class="slide">
  <div class="slide-header"><h1>(( slide.title | default('Investment') | e ))</h1></div>
  <div class="header-accent"></div>
  <div class="slide-body">
    <div class="inv-table-wrap">
      (% for phase in slide.phases %)
      <div class="inv-phase-block">
        <div class="inv-phase-name">(( phase.name | e ))(% if phase.get('duration') %) &nbsp;·&nbsp; (( phase.get('duration') | e ))(% endif %)</div>
        <table class="inv-table">
          <thead>
            <tr>
              <th>Service</th>
              <th class="right">Qty</th>
              <th class="right">Rate ((  currency | e  ))</th>
              <th class="right">Total ((  currency | e  ))</th>
            </tr>
          </thead>
          <tbody>
            (% for item in phase.line_items %)
            <tr>
              <td>(( item.service | e ))</td>
              <td class="right">(( item.get('quantity', '') ))(% if item.get('unit') %) (( item.get('unit') | e ))(% endif %)</td>
              <td class="right">(% if item.get('rate_usd') %)(( item.get('rate_usd') | currency ))(% endif %)</td>
              <td class="right">(( item.total_usd | currency ))</td>
            </tr>
            (% endfor %)
            (% set phase_total = phase.line_items | map(attribute='total_usd') | sum | default(0) %)
            <tr class="inv-total-row">
              <td colspan="3">Phase Total</td>
              <td class="right">(( phase_total | currency ))</td>
            </tr>
          </tbody>
        </table>
      </div>
      (% endfor %)

      <div class="inv-grand-total">
        <span class="inv-grand-label">Total Engagement</span>
        (% set gt = namespace(val=0) %)
        (% for phase in slide.phases %)
          (% for item in phase.line_items %)
            (% set gt.val = gt.val + item.total_usd %)
          (% endfor %)
        (% endfor %)
        <span class="inv-grand-value">(( currency )) (( gt.val | currency ))</span>
      </div>

      (% if slide.get('notes') %)
      <ul class="inv-notes">
        (% for note in slide.get('notes') %)
        <li>(( note | e ))</li>
        (% endfor %)
      </ul>
      (% endif %)
    </div>
  </div>
  <div class="slide-footer">
    <span class="footer-left">(( client_name | e ))(% if client_name and eng_title %)<span class="footer-sep">|</span>(% endif %)(( eng_title | e ))</span>
    <span class="footer-right">(( ns.idx )) / ??</span>
  </div>
</div>
