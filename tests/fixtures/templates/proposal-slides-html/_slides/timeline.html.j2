(% set client_name = document.slides | selectattr('type','eq','cover') | map(attribute='client') | first | default('') %)
(% set eng_title = document.slides | selectattr('type','eq','cover') | map(attribute='title') | first | default('') %)
<div class="slide">
  <div class="slide-header"><h1>(( slide.title | default('Project Roadmap') | e ))</h1></div>
  <div class="header-accent"></div>
  <div class="slide-body">
    <div class="timeline-phases">
      (% for phase in slide.phases %)
      <div class="phase">
        <div class="phase-header">
          <div class="phase-label">(( phase.name | e ))</div>
          (% if phase.duration %)
          <div class="phase-duration">(( phase.duration | e ))</div>
          (% endif %)
        </div>
        <div class="phase-body">
          (% if phase.activities %)
          <div class="phase-section-label">Activities</div>
          <ul class="phase-items">
            (% for a in phase.activities %)
            <li>(( a | e ))</li>
            (% endfor %)
          </ul>
          (% endif %)
          (% if phase.deliverables %)
          <div class="phase-section-label">Deliverables</div>
          <ul class="phase-items">
            (% for d in phase.deliverables %)
            <li>(( d | e ))</li>
            (% endfor %)
          </ul>
          (% endif %)
        </div>
      </div>
      (% endfor %)
    </div>
  </div>
  <div class="slide-footer">
    <span class="footer-left">(( client_name | e ))(% if client_name and eng_title %)<span class="footer-sep">|</span>(% endif %)(( eng_title | e ))</span>
    <span class="footer-right">(( ns.idx )) / ??</span>
  </div>
</div>
