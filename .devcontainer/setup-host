#!/usr/bin/env bash

if [ -n "$CODESPACES" ]
then
  echo "GITHUB_TOKEN=$(gh auth token)" > .env

else
  if [ -e ".env" ]
  then
    source .env
    echo "$GHCR_TOKEN" | docker login ghcr.io \
      -u "$(git config --get user.email)" \
      --password-stdin
  else
    echo "GITHUB_TOKEN=$(gh auth token)" > .env
  fi
fi

export PROJECT=$(git remote get-url origin 2>/dev/null | awk -F'[:/]' '{gsub(/\.git$/, "", $NF); print $NF}')
export ORGANIZATION=$(git remote get-url origin 2>/dev/null | sed -E 's|.*[:/]([^/]+)/[^/]+\.git$|\1|')

# Fallback for repos without a remote yet
PROJECT=${PROJECT:-forma}
ORGANIZATION=${ORGANIZATION:-slivern-corporate-services}

export DEV_CONTAINER_NAME="$ORGANIZATION/$PROJECT"

echo "PROJECT=$PROJECT" >> .env
echo "ORGANIZATION=$ORGANIZATION" >> .env
echo "DEV_CONTAINER_NAME=$DEV_CONTAINER_NAME" >> .env
echo "COMPOSE_BAKE=true" >> .env
