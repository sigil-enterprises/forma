\color{textmain}

% ── Section formatting ────────────────────────────────────────────────────
\titleformat{\section}{\Large\bfseries\color{primary}}{}{0em}{}[\textcolor{accent}{\titlerule[1.5pt]}]
\titleformat{\subsection}{\large\bfseries\color{primary}}{}{0em}{}
\titleformat{\subsubsection}{\normalsize\bfseries\color{accent}}{}{0em}{}

