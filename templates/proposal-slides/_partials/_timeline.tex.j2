(% for phase in content.timeline.phases %)
\begin{frame}{Timeline — (( phase.name | latex_escape ))}
  \accentrule\\[0.3cm]
  \textcolor{primary}{\bfseries Duration:} (( phase.duration | latex_escape ))\\[0.4cm]
  \begin{columns}[T]
    (% if phase.activities %)
    \begin{column}{0.48\textwidth}
      \textcolor{accent}{\bfseries Activities}
      \begin{itemize}
        (% for a in phase.activities %)
        \item \small (( a | latex_escape ))
        (% endfor %)
      \end{itemize}
    \end{column}
    (% endif %)
    (% if phase.deliverables %)
    \begin{column}{0.48\textwidth}
      \textcolor{accent}{\bfseries Deliverables}
      \begin{itemize}
        (% for d in phase.deliverables %)
        \item \small (( d | latex_escape ))
        (% endfor %)
      \end{itemize}
    \end{column}
    (% endif %)
  \end{columns}
\end{frame}
(% endfor %)
