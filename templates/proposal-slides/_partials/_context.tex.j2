\begin{frame}{The Problem}
  \accentrule\\[0.3cm]
  (( content.context.problem_statement | latex_escape ))
  (% if content.context.pain_points %)
  \\[0.4cm]
  \begin{columns}[T]
    (% for pain in content.context.pain_points %)
    \begin{column}{0.45\textwidth}
      \textcolor{accent}{\bfseries (( pain.title | latex_escape )) }\\[0.2cm]
      \small (( pain.description | latex_escape ))
    \end{column}
    (% if loop.index is odd and not loop.last %)
    \hfill
    (% endif %)
    (% endfor %)
  \end{columns}
  (% endif %)
\end{frame}

(% if content.context.current_state and content.context.current_state.metrics %)
\begin{frame}{Current State}
  \accentrule\\[0.4cm]
  (% if content.context.current_state.description %)
  (( content.context.current_state.description | latex_escape ))\\[0.4cm]
  (% endif %)
  \begin{columns}[c]
    (% for metric in content.context.current_state.metrics %)
    \begin{column}{0.2\textwidth}
      \centering
      {\color{accent}\Huge\bfseries (( metric.value | latex_escape )) }\\
      {\small (( metric.label | latex_escape )) }
    \end{column}
    (% endfor %)
  \end{columns}
\end{frame}
(% endif %)
